{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stores user-specific information and preferences.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The unique ID of the user." },
        "displayName": { "type": "string", "description": "The user's display name." },
        "email": { "type": "string", "format": "email", "description": "The user's email address." },
        "photoURL": { "type": "string", "description": "The user's profile picture URL." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the profile was created." }
      },
      "required": ["uid", "email"]
    },
    "CustomScenario": {
      "title": "Custom Scenario",
      "description": "An ethical dilemma created by a user.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique ID for the scenario." },
        "userId": { "type": "string", "description": "The UID of the creator." },
        "description": { "type": "string", "description": "The text description of the dilemma." },
        "sideA": { "type": "object", "description": "Configuration for side A." },
        "sideB": { "type": "object", "description": "Configuration for side B." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the scenario was saved." }
      },
      "required": ["id", "userId", "description", "sideA", "sideB"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profile documents."
    },
    "/scenarios/{scenarioId}": {
      "schema": "CustomScenario",
      "description": "Publicly available or user-specific custom scenarios."
    }
  }
}
